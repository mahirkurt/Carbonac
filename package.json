{
  "name": "carbon-markdown-pdf",
  "version": "1.0.0",
  "description": "Convert markdown to print-ready PDFs using IBM Carbon Design System, Gemini 3 Pro, and Paged.js",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "carbon-pdf": "./src/cli.js",
    "carbon-advisor": "./src/ai/advisor-cli.js"
  },
  "scripts": {
    "convert:paged": "node src/convert-paged.js",
    "convert": "node src/cli.js",
    "example": "node src/cli.js examples/sample.md",
    "advisor": "node src/ai/advisor-cli.js",
    "advisor:analyze": "node src/ai/advisor-cli.js analyze",
    "advisor:chat": "node src/ai/advisor-cli.js chat",
    "advisor:tips": "node src/ai/advisor-cli.js tips",
    "test": "node src/test.js"
  },
  "keywords": [
    "markdown",
    "pdf",
    "carbon",
    "ibm",
    "pagedjs",
    "print",
    "report",
    "gemini"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@carbon/colors": "^11.23.1",
    "@carbon/layout": "^11.22.1",
    "@carbon/themes": "^11.35.1",
    "@carbon/type": "^11.28.1",
    "@puppeteer/browsers": "^2.3.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "mustache": "^4.2.0",
    "pagedjs": "^0.4.3",
    "puppeteer": "^22.15.0",
    "puppeteer-core": "^22.15.0",
    "yaml": "^2.3.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prettier": "^3.2.4"
  }
}
